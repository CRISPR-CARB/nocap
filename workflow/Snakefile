"""Snakemake workflow for σ-separation single-door edge classification.

Rules
-----
prepare   : list all directed edges, shard into JSON files (shard_size edges each)
classify  : scatter — classify one shard (calls cyclic_single_door_classify.py)
gather    : merge all shard results into a single CSV + summary JSON
preprocess: (optional) greedy intervention rescue — maximize_identifiable_edges

Usage (local)
-------------
    snakemake --cores 4 --configfile workflow/config.yaml

Usage (SLURM via snakemake --slurm executor)
--------------------------------------------
    snakemake --profile workflow/profiles/slurm --configfile workflow/config.yaml

Configuration keys (workflow/config.yaml)
-----------------------------------------
    graphml     : path to the input GraphML file
    supptable   : path to supplementary table CSV (optional, for metadata join)
    n_shards    : number of scatter shards = number of SLURM nodes to use (default 179)
    shard_size  : edges per shard — fallback when n_shards is not set (default 500)
    k           : greedy rescue budget (default 10)
    outdir      : output directory (default results/cyclic_single_door)
"""

from pathlib import Path

configfile: "workflow/config.yaml"

# ---------------------------------------------------------------------------
# Derived paths
# ---------------------------------------------------------------------------

OUTDIR      = Path(config.get("outdir", "results/cyclic_single_door"))
SHARD_DIR   = OUTDIR / "shards"
GRAPHML     = config["graphml"]
N_SHARDS    = int(config["n_shards"]) if "n_shards" in config else None
SHARD_SIZE  = int(config.get("shard_size", 500))
K           = int(config.get("k", 10))

# Absolute path to the repository root (this file lives in workflow/, so
# basedir == workflow/ and its parent is the repo root).  Passed to every
# shell block so `cd {REPO_ROOT}` makes relative paths and uv work
# correctly on SLURM nodes that may launch jobs from an arbitrary CWD.
REPO_ROOT   = Path(workflow.basedir).parent

# uv cache directory on the same filesystem as the project so that uv can use
# hardlinks instead of copies when installing into the project venv.  Without
# this, uv falls back to full copies when the default ~/.cache/uv is on a
# different filesystem (e.g. NFS home on /people vs. project on /qfs).
UV_CACHE    = REPO_ROOT / ".uv-cache"

# ---------------------------------------------------------------------------
# Helper: determine shard IDs after prepare runs
# ---------------------------------------------------------------------------

checkpoint prepare:
    """List all directed edges and shard them into JSON files."""
    input:
        graphml = GRAPHML,
    output:
        shard_dir = directory(str(SHARD_DIR)),
        manifest  = str(OUTDIR / "shard_manifest.json"),
    params:
        n_shards   = N_SHARDS,
        shard_size = SHARD_SIZE,
    resources:
        mem_mb  = 4000,
        runtime = 30,
    run:
        import subprocess, sys
        cmd = [
            "uv", "run", "python",
            "scripts/cyclic_single_door_classify.py", "prepare",
            "--graphml", input.graphml,
            "--shard-dir", output.shard_dir,
            "--manifest", output.manifest,
        ]
        if params.n_shards is not None:
            cmd += ["--n-shards", str(params.n_shards)]
        else:
            cmd += ["--shard-size", str(params.shard_size)]
        env = dict(__import__("os").environ)
        env["UV_CACHE_DIR"] = str(UV_CACHE)
        subprocess.run(cmd, check=True, cwd=str(REPO_ROOT), env=env)


def _shard_ids(wildcards):
    """Return list of shard IDs after the prepare checkpoint completes."""
    import json
    manifest_path = checkpoints.prepare.get(**wildcards).output.manifest
    with open(manifest_path) as f:
        manifest = json.load(f)
    return manifest["shard_ids"]


# ---------------------------------------------------------------------------
# classify — scatter: one job per shard
# ---------------------------------------------------------------------------

rule classify:
    """Classify all edges in one shard under the sigma-single-door criterion."""
    input:
        graphml = GRAPHML,
        shard   = str(SHARD_DIR / "shard_{shard_id}.json"),
    output:
        result  = str(OUTDIR / "classified" / "shard_{shard_id}.json"),
    resources:
        mem_mb  = 8000,
        runtime = 120,   # 2 h; actual observed max is ~1 h, giving 2× safety margin
    shell:
        """
        export UV_CACHE_DIR={UV_CACHE}
        cd {REPO_ROOT} && \
        uv run python scripts/cyclic_single_door_classify.py classify \
            --graphml {input.graphml} \
            --shard {input.shard} \
            --output {output.result}
        """


# ---------------------------------------------------------------------------
# gather — merge all classified shards
# ---------------------------------------------------------------------------

rule gather:
    """Merge all classified shard results into a single CSV and summary JSON."""
    input:
        results = lambda wildcards: expand(
            str(OUTDIR / "classified" / "shard_{shard_id}.json"),
            shard_id=_shard_ids(wildcards),
        ),
    output:
        csv     = str(OUTDIR / "classification_results.csv"),
        summary = str(OUTDIR / "classification_summary.json"),
    resources:
        mem_mb  = 4000,
        runtime = 30,
    shell:
        """
        export UV_CACHE_DIR={UV_CACHE}
        cd {REPO_ROOT} && \
        uv run python scripts/cyclic_single_door_gather.py \
            --input-dir {OUTDIR}/classified \
            --output-csv {output.csv} \
            --output-summary {output.summary}
        """


# ---------------------------------------------------------------------------
# preprocess — greedy intervention rescue (optional)
# ---------------------------------------------------------------------------

rule preprocess:
    """Greedy rescue: maximize identifiable edges via up to k interventions."""
    input:
        graphml = GRAPHML,
    output:
        rescue_csv    = str(OUTDIR / "rescue_curve.csv"),
        rescue_json   = str(OUTDIR / "rescue_result.json"),
    params:
        k = K,
    resources:
        mem_mb  = 8000,
        runtime = 300,
    shell:
        """
        export UV_CACHE_DIR={UV_CACHE}
        cd {REPO_ROOT} && \
        uv run python scripts/cyclic_single_door_classify.py preprocess \
            --graphml {input.graphml} \
            --k {params.k} \
            --output-csv {output.rescue_csv} \
            --output-json {output.rescue_json}
        """


# ---------------------------------------------------------------------------
# Default target: full classification pipeline
# ---------------------------------------------------------------------------

rule all:
    """Run the full classification pipeline (prepare → classify → gather)."""
    default_target: True
    input:
        rules.gather.output.csv,
        rules.gather.output.summary,
